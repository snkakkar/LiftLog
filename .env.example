# Postgres (Neon, etc.) for local + production. Add ?pgbouncer=true for pooler URLs.
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require&pgbouncer=true"

# NextAuth (required for sign-in). Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Admin dashboard access (comma-separated emails)
ADMIN_EMAILS="migrated@liftlog.local"
