// LiftLog - Multi-user fitness app. Auth via NextAuth Credentials.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  passwordHash   String
  createdAt      DateTime  @default(now())

  programs       Program[]
  profile        Profile?
  bodyMetricLogs BodyMetricLog[]
}

model Program {
  id          String    @id @default(cuid())
  userId      String?   // optional during migration; set by scripts/migrate-to-multi-user
  name        String
  description String?
  createdAt   DateTime  @default(now())
  archivedAt  DateTime?

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  weeks  Week[]
}

model Week {
  id         String    @id @default(cuid())
  programId  String
  weekNumber Int
  startDate  DateTime? // optional: week start (e.g. Monday) for display
  program    Program   @relation(fields: [programId], references: [id], onDelete: Cascade)

  days WorkoutDay[]
}

model WorkoutDay {
  id         String   @id @default(cuid())
  weekId     String
  dayNumber  Int
  name       String?  // e.g. "Push", "Pull", "Legs"
  week       Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)

  exercises Exercise[]
  sessions  WorkoutSession[]
}

model Exercise {
  id             String   @id @default(cuid())
  workoutDayId   String
  name           String
  orderIndex     Int      @default(0)
  substitution1  String?
  substitution2  String?
  workoutDay     WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  templateSets   ExerciseSet[]
  loggedSets     LoggedSet[]
  displayOverrides ExerciseOverride[]
}

model ExerciseSet {
  id           String   @id @default(cuid())
  exerciseId   String
  setNumber   Int
  targetReps  Int?
  targetWeight Float?
  targetRir   Int?
  exercise     Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

model WorkoutSession {
  id           String   @id @default(cuid())
  workoutDayId String
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  workoutDay   WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)

  loggedSets      LoggedSet[]
  exerciseOverrides ExerciseOverride[]
}

model ExerciseOverride {
  id               String   @id @default(cuid())
  workoutSessionId String
  exerciseId       String
  displayName     String
  note            String?

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise       Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutSessionId, exerciseId])
}

model LoggedSet {
  id               String   @id @default(cuid())
  workoutSessionId String
  exerciseId       String
  setNumber        Int
  reps             Int?
  weight           Float?
  rir              Int?     // Reps in reserve (1-4 typical)
  isWarmup         Boolean? @default(false)
  completedAt      DateTime @default(now())

  workoutSession WorkoutSession @relation(fields: [workoutSessionId], references: [id], onDelete: Cascade)
  exercise       Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
}

// Per-user profile (height, age, gender). One row per user.
model Profile {
  id        String   @id @default(cuid())
  userId    String?  @unique // optional during migration
  heightCm  Float?
  age       Int?
  gender    String?
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Daily log of body metrics (weight, body fat %) for progression/summary. One per user per day.
model BodyMetricLog {
  id        String   @id @default(cuid())
  userId    String?  // optional during migration
  date      DateTime
  weightLb  Float?
  bodyFatPct Float?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
